# ================================================================
# 飞书应用凭证
# ================================================================
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 飞书 Webhook 安全配置（在飞书开放平台配置的校验 Token 和加密 Key）
FEISHU_VERIFY_TOKEN=xxx
FEISHU_ENCRYPT_KEY=           # 留空表示不加密

# ================================================================
# 机器人服务用户（机器人主要服务的用户）
# ================================================================
BOT_OWNER_NAME=你的名字         # 机器人称呼你的名字
BOT_OWNER_OPEN_ID=ou_xxx      # 你的飞书 open_id，用于日历权限等

# ================================================================
# Anthropic API
# ================================================================
ANTHROPIC_API_KEY=sk-ant-xxx

# ================================================================
# 定时任务配置（日系项目风险总结）
# ================================================================
# 每周五下午5点发送周报
WEEKLY_SUMMARY_CRON=0 17 * * 5
# 项目风险 Bitable
RISK_BITABLE_APP_TOKEN=
RISK_BITABLE_TABLE_ID=
